# Neon PostgreSQL connection string.
# Production should use the Neon pooled URL.
DATABASE_URL=

# NextAuth.
# Local: http://localhost:3000
# Production: https://your-domain.vercel.app or your custom domain.
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth web client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Only these two Google accounts can sign in.
HAYDEN_GOOGLE_EMAIL=
CONSTANCE_GOOGLE_EMAIL=

# Display name created by seed.
FAMILY_NAME=CoCare Family

# Email notifications through Resend.
# Leave RESEND_API_KEY empty locally if you want email sending to be skipped.
RESEND_API_KEY=
EMAIL_FROM=Care Calendar <notifications@your-domain.com>

# Used in email links. Production should match NEXTAUTH_URL.
APP_BASE_URL=http://localhost:3000
